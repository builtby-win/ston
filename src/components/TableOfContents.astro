---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const items = headings.filter(({ depth }) => depth === 2);
---

{items.length > 0 && (
  <nav class="toc" aria-label="Table of contents">
    <p class="toc-title">on this page</p>
    <ol>
      {items.map((heading) => (
        <li>
          <a href={`#${heading.slug}`}>{heading.text}</a>
        </li>
      ))}
    </ol>
  </nav>
)}

<style>
  .toc {
    background: var(--color-term-bg-lighter);
    border: 1px solid #30363d;
    border-radius: 0.375rem;
    padding: 1rem 1.25rem;
  }

  .toc-title {
    color: var(--color-term-branch);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    margin: 0 0 0.75rem;
    text-transform: uppercase;
  }

  ol {
    list-style: none;
    margin: 0;
    padding: 0;
    columns: 2;
    column-gap: 2rem;
  }

  li + li {
    margin-top: 0.55rem;
  }

  li {
    break-inside: avoid;
  }


  a {
    color: var(--color-term-fg-muted);
    display: block;
    font-size: 0.78rem;
    line-height: 1.4;
    text-decoration: none;
    transition: color 0.15s;
  }

  a:hover {
    color: var(--color-term-link);
  }

  @media (max-width: 40rem) {
    ol {
      columns: 1;
    }
  }

</style>
