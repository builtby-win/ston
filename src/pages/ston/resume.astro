---
import BlogLayout from '../../layouts/BlogLayout.astro'

const timeline = [
  {
    role: 'Solo projects',
    dates: 'Aug 2022 — Present',
    summary: 'Things I’ve been building after DoorDash: small products, client sites, and content.',
    groups: [
      {
        label: null,
        items: [
          {
            name: 'back2vibing',
            dates: 'Dec 2025 — Present',
            url: 'https://back2vibing.builtby.win/',
            description:
              'A Tauri desktop app built with Rust, React, TypeScript, and an Objective-C macOS bridge. It coordinates parallel AI coding sessions, surfaces sessions that need input, permission, or review, and opens the relevant tmux session.',
            links: [],
          },
          {
            name: 'areyougo.ing',
            dates: 'Dec 2025 — Present',
            url: 'https://areyougo.ing/',
            description:
              'A React web app on Astro, hosted on Cloudflare with self-hosted services deployed through Coolify. It syncs ticket inboxes through IMAP and uses DeepSeek V4 Flash to parse ticket-email XML and automatically update event attendance.',
            links: [],
          },
          {
            name: 'Zero Stack',
            dates: 'Jan 2026 — Present',
            url: 'https://zerostack.builtby.win/',
            description:
              "I'm using Zero Stack to help non-technical small business owners start vibe coding real sites and apps. Examples:",
            links: [
              {
                label: 'CFW Productions',
                url: 'https://cfwproductions.com/',
              },
              {
                label: 'Flash',
                url: 'https://flash.handlworks.com/',
              },
              {
                label: 'Import Bonds',
                url: 'https://import-bonds.reddata.io/',
              },
            ],
          },
          {
            name: 'Import Magic',
            dates: 'Aug 2022 — Present',
            url: 'https://importmagic.app',
            description:
              'An Electron + React desktop app launched for Windows and macOS to automate media offloading and duplicate detection.',
            links: [],
          },
          {
            name: 'YouTube',
            dates: '2024 — 1 month',
            url: 'https://youtube.com/@winnieletsgo',
            description:
              'I always wanted to make videos, so before I turned 30 I made 30 videos in 30 days and grew the channel to around 1k subscribers.',
            links: [],
          },
        ],
      },
    ],
  },
  {
    role: 'DoorDash',
    dates: 'Aug 2019 — Aug 2022',
    summary:
      'I worked on two teams: SWAT and Shopping Experience, building 0 → 1 projects across the entire stack.',
    groups: [
      {
        label: 'SWAT team',
        items: [
          {
            name: 'Japan + Germany launch',
            dates: null,
            url: null,
            description:
              "I was part of the team leading DoorDash's Japan and Germany launches. The hard part was tech debt: localizing copy, supporting different currency, and finding all the weird edge cases that show up when a product goes international.",
            links: [
              {
                label: 'I wrote this technical blog about the launch work here.',
                url: 'https://careersatdoordash.com/blog/overcoming-localization-internalization-challenges/',
              },
            ],
          },
          {
            name: 'GDPR privacy compliance',
            dates: null,
            url: null,
            description:
              'As we were launching Germany, I led a cross-functional team of 15 between legal and engineering to meet EU privacy standards and unblock the Germany launch.',
            links: [],
          },
          {
            name: 'Japanese Dasher payouts',
            dates: null,
            url: null,
            description:
              "Japan was DoorDash's first country outside North America, and Stripe KYC required IDs the Dasher app didn't support yet. I led a last-minute full-stack team to add the missing ID support and ship Dasher payouts before launch.",
            links: [],
          },
        ],
      },
      {
        label: 'Shopping Experience team',
        items: [
          {
            name: 'Item modal rebuild',
            dates: null,
            url: null,
            description:
              "Probably the most technically difficult project I've worked on in my career: rebuilding DoorDash's most complex UI component.",
            links: [
              {
                label: 'I wrote this technical blog about it here.',
                url: 'https://careersatdoordash.com/blog/managing-react-state-using-the-class-pattern/',
              },
            ],
          },
          {
            name: 'Impossible item validation',
            dates: null,
            url: null,
            description:
              'Identified ~50k requests/day trying to create impossible order-to-item states, then assembled a team across merchant orgs and my team to add backend validation before those items entered the system.',
            links: [],
          },
          {
            name: 'DoorDash landing page',
            dates: null,
            url: 'https://www.doordash.com/',
            description: 'Built the DoorDash landing page that is still used today.',
            links: [],
          },
          {
            name: 'Item re-ordering',
            dates: null,
            url: null,
            description: 'Built item re-ordering for shopping flows.',
            links: [],
          },
        ],
      },
    ],
  },
  {
    role: 'SigFig',
    dates: 'Apr 2018 — Aug 2019',
    summary: 'Software engineer.',
    groups: [],
  },
  {
    role: 'FinancialForce',
    dates: 'Apr 2017 — Apr 2018',
    summary: 'Software engineer.',
    groups: [],
  },
]
---

<BlogLayout
    title="resume"
    description="What Winston has built, as an IC and a leader"
    pathSegments={[{ name: "resume", href: null }]}
    backHref="/ston"
>
    <header class="page-header">
        <h1>resume/</h1>
        <p class="page-description">What I've built</p>
    </header>

    <section class="intro-section">
        <p>
            I've been a software engineer for about 10 years. I studied chemical
            engineering at UCLA and did a coding bootcamp after graduating. Here
            are some things I've built and shipped that I'm really proud of.
        </p>
        <p class="contact-line">
            contact: <a href="mailto:ston@builtby.win">ston@builtby.win</a>
        </p>
        <p class="contact-line">
            download: <a href="/Winston-Zhao-Resume.pdf" download>resume (pdf)</a>
        </p>
    </section>

    <section class="timeline">
        <h2>Timeline:</h2>

        {
            timeline.map((entry) => (
                <article class="timeline-entry">
                    <div class="timeline-header">
                        <h3 class="timeline-title">{entry.role}</h3>
                        <span class="timeline-date">{entry.dates}</span>
                    </div>
                    {entry.summary ? (
                        <p class="timeline-summary">{entry.summary}</p>
                    ) : null}
                    {entry.groups.map((group) => (
                        <div class="item-group">
                            {group.label ? (
                                <h4 class="team-label">{group.label}</h4>
                            ) : null}
                            <ul class="items-list">
                                {group.items.map((item) => (
                                    <li class="item">
                                        <div class="item-header">
                                            {item.url ? (
                                                <a
                                                    href={item.url}
                                                    target="_blank"
                                                    rel="noopener noreferrer"
                                                    class="item-name"
                                                >
                                                    {item.name}
                                                </a>
                                            ) : (
                                                <span class="item-name">
                                                    {item.name}
                                                </span>
                                            )}
                                            {item.dates ? (
                                                <span class="item-date">
                                                    {item.dates}
                                                </span>
                                            ) : null}
                                        </div>
                                        <p class="item-description">
                                            {item.description}
                                            {item.links.length > 0 ? (
                                                <>
                                                    {" "}
                                                    {item.links.map(
                                                        (link, index) => (
                                                            <>
                                                                <a
                                                                    href={link.url}
                                                                    target="_blank"
                                                                    rel="noopener noreferrer"
                                                                >
                                                                    {link.label}
                                                                </a>
                                                                {index <
                                                                item.links
                                                                    .length -
                                                                    1
                                                                    ? ", "
                                                                    : null}
                                                            </>
                                                        ),
                                                    )}
                                                </>
                                            ) : null}
                                        </p>
                                    </li>
                                ))}
                            </ul>
                        </div>
                    ))}
                </article>
            ))
        }
    </section>
</BlogLayout>

<style>
    .page-header {
        margin-bottom: 2rem;
    }

    .page-header h1 {
        font-size: 1.5rem;
        font-weight: 600;
        color: var(--color-term-dir);
        margin: 0 0 0.5rem 0;
    }

    .page-description {
        color: var(--color-term-fg-muted);
        font-size: 0.875rem;
        margin: 0;
    }

    .intro-section {
        margin-bottom: 3rem;
    }

    .intro-section p {
        color: var(--color-term-fg);
        font-size: 0.95rem;
        line-height: 1.7;
        margin: 0;
    }

    .contact-line {
        color: var(--color-term-fg-muted);
        font-size: 0.875rem;
        line-height: 1.6;
        margin: 1rem 0 0;
    }

    .contact-line a {
        color: var(--color-term-link);
        text-decoration: underline;
        text-underline-offset: 2px;
    }

    .timeline {
        margin-top: 3rem;
    }

    .timeline h2 {
        font-size: 1rem;
        font-weight: 500;
        color: var(--color-term-dir);
        margin: 0 0 1.5rem 0;
    }

    .timeline-entry {
        border-left: 2px solid var(--color-term-fg-muted);
        margin-bottom: 2.5rem;
        padding-left: 1rem;
    }

    .timeline-header,
    .item-header {
        display: flex;
        align-items: baseline;
        flex-wrap: wrap;
        gap: 0.625rem;
        margin-bottom: 0.5rem;
    }

    .timeline-title {
        font-size: 0.95rem;
        font-weight: 500;
        color: var(--color-term-purple);
        margin: 0;
    }

    .timeline-date,
    .item-date {
        font-size: 0.75rem;
        color: var(--color-term-fg-muted);
    }

    .timeline-summary {
        color: var(--color-term-fg);
        font-size: 0.875rem;
        line-height: 1.6;
        margin: 0;
        opacity: 0.85;
    }

    .item-group {
        margin-top: 1rem;
    }

    .team-label {
        color: var(--color-term-fg-muted);
        font-size: 0.8rem;
        font-weight: 500;
        margin: 0 0 0.75rem 0;
    }

    .items-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        margin: 0 0 0 1.25rem;
        padding: 0;
    }

    .item {
        padding-left: 0.25rem;
    }

    .item::marker {
        color: var(--color-term-fg-muted);
    }

    .item-name {
        font-weight: 500;
        color: var(--color-term-link);
        text-decoration: none;
        transition: opacity 0.15s;
    }

    a.item-name:hover {
        opacity: 0.8;
    }

    .item-description {
        color: var(--color-term-fg);
        font-size: 0.875rem;
        margin: 0;
        line-height: 1.6;
        opacity: 0.85;
    }

    .item-description a {
        color: var(--color-term-link);
        text-decoration: underline;
        text-underline-offset: 2px;
    }

    .item-description a:hover {
        color: var(--color-term-prompt);
    }
</style>
